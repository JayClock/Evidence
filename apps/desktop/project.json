{
  "name": "@evidence/desktop",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/desktop/src-tauri/src",
  "projectType": "application",
  "tags": ["scope:desktop", "type:tauri", "type:rust"],
  "implicitDependencies": ["@evidence/web"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/desktop",
        "command": "pnpm tauri dev"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/target/release/bundle"],
      "options": {
        "cwd": "apps/desktop",
        "command": "pnpm tauri build --bundles app"
      }
    },
    "build-frontend": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/apps/web/dist"],
      "options": {
        "command": "pnpm nx build @evidence/web"
      }
    },
    "rust-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo build -p evidence-desktop"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo test -p evidence-desktop"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo clippy -p evidence-desktop --all-targets -- -D warnings"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo fmt -p evidence-desktop"
      }
    }
  }
}
