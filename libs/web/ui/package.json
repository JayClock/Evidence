{
  "name": "@evidence/ui",
  "version": "0.0.1",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components/ui/*": {
      "types": "./src/components/ui/*.tsx",
      "import": "./src/components/ui/*.tsx",
      "default": "./src/components/ui/*.tsx"
    },
    "./components/ai-elements/*": {
      "types": "./src/components/ai-elements/*.tsx",
      "import": "./src/components/ai-elements/*.tsx",
      "default": "./src/components/ai-elements/*.tsx"
    },
    "./ui/*": {
      "types": "./src/components/ui/*.tsx",
      "import": "./src/components/ui/*.tsx",
      "default": "./src/components/ui/*.tsx"
    },
    "./ai-elements/*": {
      "types": "./src/components/ai-elements/*.tsx",
      "import": "./src/components/ai-elements/*.tsx",
      "default": "./src/components/ai-elements/*.tsx"
    },
    "./styles.css": "./src/styles.css",
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "ai-elements": "^1.9.0",
    "tailwindcss": "^4.3.0"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@hateoas-ts/resource": "^1.4.3",
    "@rjsf/core": "^6.5.3",
    "@rjsf/shadcn": "^6.5.3",
    "@rjsf/utils": "^6.5.3",
    "@rjsf/validator-ajv8": "^6.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
