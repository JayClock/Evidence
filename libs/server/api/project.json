{
  "name": "@evidence/server-api",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/server/api/src",
  "projectType": "library",
  "tags": ["scope:server", "type:rust", "layer:api"],
  "implicitDependencies": ["@evidence/server-domain"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo build -p evidence-server-api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo test -p evidence-server-api"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo clippy -p evidence-server-api --all-targets -- -D warnings"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo fmt -p evidence-server-api"
      }
    },
    "format-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo fmt -p evidence-server-api -- --check"
      }
    }
  }
}
