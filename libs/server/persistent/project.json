{
  "name": "@evidence/server-persistent",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/server/persistent/src",
  "projectType": "library",
  "tags": ["scope:server", "type:rust", "layer:persistent"],
  "implicitDependencies": ["@evidence/server-domain"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo build -p evidence-server-persistent --features postgres"
      }
    },
    "build-sqlite": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo build -p evidence-server-persistent --no-default-features --features sqlite"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo test -p evidence-server-persistent"
      }
    },
    "test-sqlite": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo test -p evidence-server-persistent --no-default-features --features sqlite-tests"
      }
    },
    "test-postgres": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo test -p evidence-server-persistent --features postgres-tests"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo clippy -p evidence-server-persistent --all-targets --features postgres -- -D warnings"
      }
    },
    "lint-sqlite": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo clippy -p evidence-server-persistent --all-targets --no-default-features --features sqlite -- -D warnings"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo fmt -p evidence-server-persistent"
      }
    },
    "format-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo fmt -p evidence-server-persistent -- --check"
      }
    },
    "ci": {
      "executor": "nx:run-commands",
      "options": {
        "parallel": false,
        "commands": [
          "pnpm nx run @evidence/server-persistent:format-check",
          "pnpm nx run @evidence/server-persistent:lint",
          "pnpm nx run @evidence/server-persistent:lint-sqlite",
          "pnpm nx run @evidence/server-persistent:test",
          "pnpm nx run @evidence/server-persistent:test-sqlite",
          "pnpm nx run @evidence/server-persistent:test-postgres",
          "pnpm nx run @evidence/server-persistent:build",
          "pnpm nx run @evidence/server-persistent:build-sqlite"
        ]
      }
    }
  }
}
